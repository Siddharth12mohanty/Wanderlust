<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top py-2">
  <div class="container-fluid px-3 px-lg-4">

    <!-- Logo -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <!-- Mobile Toggle -->
    <button
      class="navbar-toggler border-0 shadow-none p-2"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar Content -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left -->
      <ul class="navbar-nav me-lg-auto mb-2 mb-lg-0 text-center text-lg-start">
        <li class="nav-item">
          <a class="nav-link fw-semibold" href="/listings">Explore</a>
        </li>
      </ul>

      <!-- Search Bar Capsule -->
      <div class="search-wrapper mx-lg-auto my-2 my-lg-0">
        <form class="search-form"
              action="/listings/search"
              method="GET">

          <div class="navbar-search-bar">
            <select class="form-select search-select-input" name="country">
              <option value="">🌍 All Countries</option>
              <% if(countries && countries.length){ %>
                <% countries.forEach(country=>{ %>
                  <option value="<%= country %>"><%= country %></option>
                <% }) %>
              <% } %>
            </select>

            <button class="btn search-icon-btn" type="submit" aria-label="Search">
              <i class="fa-solid fa-magnifying-glass"></i>
              <span class="ms-1 search-btn-text">Search</span>
            </button>
          </div>

        </form>
      </div>

      <!-- Right Nav Items & Auth -->
      <ul class="navbar-nav ms-lg-auto text-center text-lg-end align-items-center gap-2 mt-2 mt-lg-0">

        <li class="nav-item w-100 w-lg-auto">
          <a class="nav-link fw-semibold px-3 py-2 rounded-pill host-nav-link" href="/listings/new">
            Airbnb your home
          </a>
        </li>

        <% if(!currUser){ %>

          <li class="nav-item w-100 w-lg-auto">
            <a class="btn btn-outline-danger btn-auth nav-signup-btn w-100 w-lg-auto" href="/signup">Sign Up</a>
          </li>

          <li class="nav-item w-100 w-lg-auto">
            <a class="btn btn-danger btn-auth nav-login-btn w-100 w-lg-auto text-white" href="/login">Log In</a>
          </li>

        <% } else { %>

          <li class="nav-item w-100 w-lg-auto">
            <a class="btn btn-outline-dark btn-auth nav-logout-btn w-100 w-lg-auto" href="/logout">Log Out</a>
          </li>

        <% } %>

      </ul>

    </div>

