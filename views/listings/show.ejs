<% layout("/layouts/boilerplate")%>
<script>
const listing = <%- JSON.stringify(listing) %>;
</script>
    <div class="row mt-4 justify-content-center">
        <div class="col-12 col-lg-8 offset-lg-0 col-md-10">

            <!-- Title & Meta Header -->
            <div class="mb-3">
                <h2 class="fw-bold mb-1 show-title"><%= listing.title %></h2>
                <div class="d-flex align-items-center gap-2 flex-wrap text-muted">
                    <span><i class="fa-solid fa-location-dot text-danger me-1"></i> <%= listing.location %>, <%= listing.country %></span>
                    <% if(listing.category){ %>
                        <span class="badge bg-light text-dark border rounded-pill px-3 py-1 fw-medium"><%= listing.category %></span>
                    <% } %>
                </div>
            </div>

            <!-- Hero Image Container -->
            <div class="show-img-container mb-4 overflow-hidden rounded-4 position-relative">
                <img src="<%= listing.image.url %>" 
                     class="card-img-top show-img w-100" 
                     alt="<%= listing.title %>">
            </div>

            <!-- Details Card -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 show-details-card">
                <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-3 flex-wrap gap-2">
                    <div>
                        <div class="d-flex align-items-center text-secondary mb-1">
                            <i class="fa-solid fa-circle-user fa-lg me-2 text-danger"></i>
                            <span class="fw-semibold">Hosted by <%= listing.owner ? listing.owner.username : 'Host' %></span>
                        </div>
                    </div>
                    <div class="text-lg-end">
                        <span class="fs-3 fw-bold text-dark">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : '0' %></span>
                        <span class="text-muted fs-6">/ night</span>
                    </div>
                </div>

                <div class="card-text text-secondary mb-3 show-desc fs-6 lh-base">
                    <%= listing.description %>
                </div>
            </div>

            <!-- Owner Controls (Edit / Delete) -->
            <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)){ %>
                <div class="d-flex align-items-center gap-3 mb-4">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger edit-btn rounded-pill px-4 py-2 fw-semibold">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit Listing
                    </a>
                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                        <button class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold">
                            <i class="fa-solid fa-trash me-1"></i> Delete Listing
                        </button>
                    </form>
                </div>
            <% } %>

            <!-- Reviews Section -->
            <div class="mb-4">
                <% if(currUser){ %>
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <h4 class="fw-bold mb-3">Leave a Review</h4>
                        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                            <div class="mb-3">
                                <label for="rating" class="form-label fw-semibold text-secondary">Rating</label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div class="mb-3">
                                <label for="comment" class="form-label fw-semibold text-secondary">Comment</label>
                                <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control rounded-3" placeholder="Share your experience..." required></textarea>
                                <div class="invalid-feedback">
                                    Please add a comment for your review.
                                </div>
                            </div>
                            <button class="btn btn-danger rounded-pill px-4 py-2 fw-semibold">Submit Review</button>
                        </form>
                    </div>
                <% } %>

                <% if(listing.reviews && listing.reviews.length > 0){ %>
                    <h4 class="fw-bold mb-3">Guest Reviews</h4>
                    <div class="row g-3 mb-4">
                        <% for(review of listing.reviews){ %>
                            <div class="col-12 col-md-6">
                                <div class="card border-0 shadow-sm rounded-4 h-100 p-3">
                                    <div class="card-body p-2 d-flex flex-column justify-content-between">
                                        <div>
                                            <div class="d-flex align-items-center mb-2">
                                                <i class="fa-solid fa-circle-user fa-lg text-secondary me-2"></i>
                                                <h6 class="card-title mb-0 fw-bold">@<%= review.author ? review.author.username : 'User' %></h6>
                                            </div>
                                            <p class="starability-result card-text mb-2" data-rating="<%= review.rating %>"></p>
                                            <p class="card-text text-secondary"><%= review.comment %></p>
                                        </div>

                                        <% if(currUser && (review.author && review.author._id.equals(currUser._id) || (listing.owner && listing.owner._id.equals(currUser._id)))){ %>
                                            <form class="mt-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                                            </form>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>

            <!-- Map Section -->
            <div class="mb-5">
                <h4 class="fw-bold mb-3">Where you will be</h4>
                <div class="rounded-4 overflow-hidden shadow-sm">
                    <div id="map"></div>
                </div>
            </div>

        </div>
    </div>

<!-- map -->
 <script src="/js/map.js"></script>